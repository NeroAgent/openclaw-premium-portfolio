{
  "name": "qwen-code",
  "description": "An open-source AI coding agent for the terminal, optimized for Qwen3-Coder. Provides code understanding, automated refactoring, test generation, and agentic workflows. Integrates with OpenAI, Anthropic, and Qwen OAuth.",
  "version": "0.1.0",
  "type": "coding",
  "binary": "qwen",
  "wrapper": "scripts/run.py",
  "install": {
    "method": "npm",
    "package": "@qwen-code/qwen-code",
    "check": "which qwen"
  },
  "auth": {
    "required": true,
    "type": "qwen_oauth_or_api_key",
    "command": "qwen /auth"
  }
}
