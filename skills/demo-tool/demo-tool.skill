{
  "name": "demo-tool",
  "description": "Demo skill for ToolRegistry pattern",
  "version": "0.1.0",
  "tools": [
    {
      "name": "echo",
      "description": "Echo back the input message",
      "input_schema": {
        "type": "object",
        "properties": {
          "message": { "type": "string" },
          "times": { "type": "integer", "minimum": 1, "default": 1 }
        },
        "required": ["message"]
      },
      "permission": "read_only"
    }
  ]
}
